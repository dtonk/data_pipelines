# Cloudflare R2 — where feed JSON is published for Low Tech Maps.
# Use a DEDICATED public bucket (e.g. ltm-public-feeds), NOT the bucket holding
# your app's internal data: R2 public access is per-bucket (all-or-nothing), so a
# shared bucket would expose internal objects too. Use an API token SCOPED to this
# one bucket (Object Read & Write) so a leaked key can't reach other data.
# Leave unset to just write local files under ./out for testing.
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ltm-public-feeds
# Public base URL of the bucket (r2.dev domain or a custom domain) — used only to
# print the final feed URL, e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=

# DuckDB warehouse file (default: ./warehouse.duckdb)
# DUCKDB_PATH=warehouse.duckdb
